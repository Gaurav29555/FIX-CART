# Root VCS ignores
.git/

# Environment and secrets
.env
.env.*
!.env.example

# Java / Maven
**/target/
**/.mvn/

# Node / Expo / React Native
**/node_modules/
**/.expo/
**/.expo-shared/

# Android / Gradle
**/.gradle/
**/build/
**/local.properties
**/*.iml

# Logs and caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary / backup files
*.bak
window_dump.xml
